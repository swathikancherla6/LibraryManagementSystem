# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml

# Env & secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Build output (safety net if commands run from root)
target/
dist/
build/
node_modules/
Option B — from the terminal directly (overwrites the file in one shot):
bashcat > .gitignore << 'EOF'
# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml

# Env & secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Build output (safety net if commands run from root)
target/
dist/
build/
node_modules/
EOF
Step 3: Update the backend .gitignore
bashcat > backend/library-management-api/.gitignore << 'EOF'
# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.classpath
.project
.settings/
bin/

# OS
.DS_Store

# Logs
*.log
logs/

# Local/secret config overrides
.env
application-local.yml
application-local.properties

# Misc
*.pid
HELP.md
EOF
Step 4: Update the frontend .gitignore
bashcat > frontend/library-management-ui/.gitignore << 'EOF'
# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Env — keep .env.example tracked, ignore the rest
.env
.env.local
.env.*.local
!.env.example

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Vite cache
.vite/
EOF